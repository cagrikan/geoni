# GEONI Visibility Scanner - Local Development Environment
# Copy this to .env and adjust values as needed

# Core Application
APP_NAME="GEONI Visibility Scanner MVP"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL="INFO"

# API Server
API_HOST="0.0.0.0"
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# Database
DATABASE_URL="postgresql://geoni_user:geoni_password@localhost:5432/geoni_scanner"
DATABASE_ECHO=false

# Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_TTL=3600

# Crawler Settings
CRAWLER_MAX_PAGES=500
CRAWLER_TIMEOUT_PER_PAGE=10
CRAWLER_TOTAL_TIMEOUT=300
CRAWLER_DELAY_MS=500
CRAWLER_USER_AGENT="GEONI-Scanner/1.0 (+https://geoni.ai/bot)"

# Celery (Background Jobs)
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND_URL="redis://localhost:6379/2"
CELERY_TASK_TIME_LIMIT=600

# External APIs (Fill in with real keys in production)
GOOGLE_API_KEY=""
GOOGLE_SEARCH_ENGINE_ID=""
BING_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# CORS
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173", "http://localhost:8000", "https://geoni.ai"]'

# Authentication
JWT_SECRET_KEY="your-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_HOURS=24
